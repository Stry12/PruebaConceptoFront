        { "nombre": "modal-agregar", "acciones": [ { "click": "[aria-label='Agregar nuevo ítem']" } ] },
        { "nombre": "card-hover", "acciones": [ { "hover": "article >> nth=0" } ] },
        { "nombre": "primer-foco", "acciones": [ { "press": "Tab" }, { "press": "Tab" }, { "press": "Tab" } ] }
      ]
    }
  ]
}
